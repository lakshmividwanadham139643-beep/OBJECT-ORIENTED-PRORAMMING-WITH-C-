#include <iostream> 
using namespace std; 
class Shape{ 
public: 
    virtual void draw() = 0; 
}; 
class Circle : public Shape{ 
public: 
    void draw() override { 
        cout << "Drawing a Circle.\n"; 
    } 
}; 
class Rectangle : public Shape { 
public: 
    void draw() override { 
        cout <<"Drawing a Rectangle.\n"; 
    } 
}; 
int main() { 
    Shape* shape; 
    Circle circle; 
    Rectangle rectangle; 
    shape = &circle; 
    shape->draw(); 
    shape = &rectangle; 
    shape->draw(); 
    return 0; 
 
} 
 
 
